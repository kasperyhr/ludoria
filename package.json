{
  "name": "ludoria",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @ludoria/web --filter @ludoria/worker run dev",
    "dev:web": "corepack pnpm --filter @ludoria/web run dev",
    "dev:worker": "corepack pnpm --filter @ludoria/worker run dev",
    "build": "corepack pnpm -r --workspace-concurrency=1 run build",
    "typecheck": "corepack pnpm -r --workspace-concurrency=1 run typecheck",
    "lint": "node scripts/lint.mjs",
    "test": "corepack pnpm -r --workspace-concurrency=1 run test",
    "check:local": "node scripts/check-local.mjs",
    "check:encoding": "node scripts/check-encoding.mjs",
    "check:preview-config": "node scripts/check-preview-config.mjs",
    "db:migrate:local": "wrangler d1 migrations apply ludoria-db --local --config apps/worker/wrangler.toml",
    "db:seed:local": "node scripts/seed-d1.mjs",
    "smoke:local": "node scripts/smoke-local.mjs",
    "smoke:preview": "node scripts/smoke-local.mjs",
    "smoke:web-preview": "node scripts/smoke-web-preview.mjs",
    "preview:plan": "node scripts/preview-plan.mjs"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "wrangler": "^4.58.0"
  }
}
