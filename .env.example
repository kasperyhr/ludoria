# Ludoria local development environment variables.
# Copy to .env and adjust. Do not put real secrets here.

APP_ENV=local

# Vite API origin (local dev uses Vite proxy at /worker-api)
VITE_LUDORIA_API_ORIGIN=/worker-api
VITE_LUDORIA_WORKER_WS_URL=ws://127.0.0.1:8787

# Future Pages deployment:
#   VITE_LUDORIA_API_ORIGIN=https://ludoria-worker.kasperyhr.workers.dev
