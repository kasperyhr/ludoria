# Ludoria local development environment variables.
# Copy to .env and adjust as needed. Do not put real secrets here.

APP_ENV=local

# Vite dev server proxies /worker-api to the Worker.
# Default Worker origin for local wrangler dev:
VITE_LUDORIA_WORKER_API_URL=/worker-api
VITE_LUDORIA_WORKER_WS_URL=ws://127.0.0.1:8787

# Worker origin override (used by Vite proxy):
# LUDORIA_WORKER_ORIGIN=http://127.0.0.1:8787
